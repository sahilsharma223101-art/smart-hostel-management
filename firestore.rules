rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return signedIn() && exists(currentUserPath());
    }

    function currentRole() {
      return currentUserExists() ? get(currentUserPath()).data.role : null;
    }

    function isStudent() {
      return currentRole() == 'student';
    }

    function isAdmin() {
      return currentRole() == 'admin';
    }

    function isSuperAdmin() {
      return currentRole() == 'superadmin';
    }

    function isElevated() {
      return isAdmin() || isSuperAdmin();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function onlyChanges(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    match /users/{userId} {
      allow read: if signedIn() && (isOwner(userId) || isElevated());

      allow create: if isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == 'student'
        && request.resource.data.email == request.auth.token.email;

      allow update: if isSuperAdmin()
        || (
          isAdmin()
          && resource.data.role == 'student'
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.roomId == resource.data.roomId
        )
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.roomId == resource.data.roomId
        );

      allow delete: if isSuperAdmin();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create, update, delete: if isElevated();
    }

    match /complaints/{complaintId} {
      allow read: if signedIn() && (isElevated() || resource.data.studentId == request.auth.uid);
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isElevated();
      allow delete: if isSuperAdmin();
    }

    match /leaveRequests/{requestId} {
      allow read: if signedIn() && (isElevated() || resource.data.studentId == request.auth.uid);
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isElevated();
      allow delete: if isSuperAdmin();
    }

    match /fees/{feeId} {
      allow read: if signedIn() && (isElevated() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isElevated();
    }

    match /notices/{noticeId} {
      allow read: if signedIn();
      allow create, update, delete: if isElevated();
    }

    match /visitors/{visitorId} {
      allow read: if signedIn() && (isElevated() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isElevated();
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn() && (isElevated() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isElevated();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && (isSuperAdmin() || resource.data.userId == request.auth.uid);
      allow create: if false;
      allow update: if isSuperAdmin()
        || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && onlyChanges(['read', 'updatedAt'])
        );
      allow delete: if isSuperAdmin();
    }

    match /systemLogs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /_internal/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
